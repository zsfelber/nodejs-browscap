{
  "name": "nodejs-browscap",
  "version": "1.0.6",
  "description": "http://browscap.org/ port for nodejs, php is not required",
  "homepage": "https://github.com/zsfelber/nodejs-browscap#readme",
  "bugs": {
    "url": "https://github.com/zsfelber/nodejs-browscap/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zsfelber/nodejs-browscap.git"
  },
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts",
      "node": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "license": "ISC",
  "author": "",
  "type": "commonjs",
  "main": "dist/index.js",
  "scripts": {
    "init": "node -r esbuild-register src/index.ts --initBrowscap",
    "test-init": "node --expose-gc -r esbuild-register src/index.ts --initBrowscapDb",
    "test": "node --expose-gc -r esbuild-register src/index.ts --testBrowscap",
    "tsdoc": "tsdoc --src=src/index.ts --types",
    "build": "npm dedupe; npx tsc; copyfiles -u 1 './src/**/*.{json,txt,md,class,sh,png,gif,jpg,svg}' dist",
    "buildAll": "npm install; npm dedupe; npx tsc; copyfiles -u 1 './src/**/*.{json,txt,md,class,sh,png,gif,jpg,svg}' dist"
  },
  "dependencies": {
    "adm-zip": "0.5.16",
    "tree-dump": "1.0.3"
  },
  "devDependencies": {
    "@types/adm-zip": "0.5.7",
    "@types/node": "24.2.0",
    "copyfiles": "2.4.1",
    "esbuild": "0.25.8",
    "esbuild-register": "3.6.0",
    "tsc-alias": "1.8.16",
    "tsdoc-markdown": "1.4.1",
    "typescript": "5.9.2"
  }
}
